! BLISS (Programmiersprache)
MODULE HELLO (MAIN) =
BEGIN
    LIBRARY 'SYS$LIBRARY:STARLET';

    EXTERNAL ROUTINE
        LIB$PUT_OUTPUT: PROCEDURE(VAR STRING: CHAR; VAR LENGTH: INTEGER);

    MAIN: PROCEDURE =
    BEGIN
        LOCAL MESSAGE: VECTOR[CHAR] INITIAL ('Hello, World!');
        LOCAL LEN: INTEGER INITIAL (13);
        LIB$PUT_OUTPUT(MESSAGE, LEN);
    END;
END.
